# Mullvad VPN Configuration for Hydrix Router
# Copy this file to local/mullvad.nix and fill in your credentials
#
# To get your credentials:
# 1. Log into https://mullvad.net/account
# 2. Go to "WireGuard configuration"
# 3. Generate a key pair or use existing
# 4. Note your private key and assigned IP address
# 5. Get public keys from: https://mullvad.net/servers/
#
# This file is gitignored - your credentials stay local
{
  # Your Mullvad WireGuard private key
  privateKey = "YOUR_PRIVATE_KEY_HERE";

  # Your assigned Mullvad IP address (from account page)
  # Format: 10.x.x.x/32
  address = "10.x.x.x/32";

  # Exit nodes to generate configs for
  # Server hostnames from: https://mullvad.net/servers/
  # Public keys from the same page (click on server for details)
  exitNodes = {
    # Switzerland - Zurich
    ch = {
      server = "ch-zrh-wg-001.relays.mullvad.net";
      publicKey = "SERVER_PUBLIC_KEY_CH";
    };
    # Sweden - Stockholm
    se = {
      server = "se-sto-wg-001.relays.mullvad.net";
      publicKey = "SERVER_PUBLIC_KEY_SE";
    };
    # Germany - Frankfurt
    de = {
      server = "de-fra-wg-001.relays.mullvad.net";
      publicKey = "SERVER_PUBLIC_KEY_DE";
    };
    # United States - New York
    us = {
      server = "us-nyc-wg-001.relays.mullvad.net";
      publicKey = "SERVER_PUBLIC_KEY_US";
    };
  };

  # Default VPN assignments for each bridge (loaded on boot)
  # Values: "direct" (no VPN), "blocked" (kill switch), or "mullvad-XX"
  defaultAssignments = {
    pentest = "direct";      # Pentesting needs direct WAN
    office = "mullvad-se";   # Sweden for banking/sensitive
    browse = "mullvad-ch";   # Switzerland for general browsing
    dev = "direct";          # Development needs direct access
  };
}
