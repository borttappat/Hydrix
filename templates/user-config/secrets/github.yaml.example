# GitHub SSH key — plaintext template (encrypt before committing!)
#
# Steps:
#   1. Copy this file: cp secrets/github.yaml.example secrets/github.yaml
#   2. Fill in your GitHub SSH private key below
#      (generate one: ssh-keygen -t ed25519 -C "your@email.com" -f ~/.ssh/github)
#      (add public key to: https://github.com/settings/keys)
#   3. Encrypt: sops -e -i secrets/github.yaml
#   4. Verify secrets/github.yaml is in .gitignore BEFORE committing
#      (the encrypted version is safe to commit; the plaintext is NOT)
#
# Once encrypted, set githubSecretsFile in your machine config:
#   hydrix.secrets.githubSecretsFile = ../secrets/github.yaml;
# Then add the VM to the secrets list:
#   hydrix.microvmHost.vms."microvm-dev".secrets = [ "github" ];
# The key will be provisioned to /mnt/vm-secrets/ssh/ inside the VM at boot.

id_ed25519: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    YOUR_GITHUB_SSH_PRIVATE_KEY_HERE
    -----END OPENSSH PRIVATE KEY-----
id_ed25519_pub: "ssh-ed25519 AAAA... your@email.com"
