# sops-nix configuration for Hydrix
#
# Setup:
#   1. Copy this file: cp .sops.yaml.example .sops.yaml
#   2. Rebuild to generate age key: ./scripts/nixbuild-ng.sh
#   3. Get your age public key: sops-age-pubkey
#   4. Replace AGE_PUBLIC_KEY_PLACEHOLDER below with your actual key
#   5. Encrypt your secrets: sops -e -i github.yaml
#
# Your age public key will look like: age1abc123def456...

creation_rules:
  - path_regex: .*\.yaml$
    age:
      - AGE_PUBLIC_KEY_PLACEHOLDER
