# GitHub SSH Key Secrets for Hydrix MicroVMs
#
# Setup:
#   1. Copy this file: cp github.yaml.example github.yaml
#   2. Replace the placeholder values with your actual SSH keys
#   3. Encrypt the file: sops -e -i github.yaml
#
# After encryption, the file will contain encrypted values that can only
# be decrypted by machines with the age key derived from the SSH host key.
#
# Generate a new SSH key for GitHub (if needed):
#   ssh-keygen -t ed25519 -C "your_email@example.com" -f ~/.ssh/github_hydrix
#   cat ~/.ssh/github_hydrix       # private key (paste below)
#   cat ~/.ssh/github_hydrix.pub   # public key (paste below)
#
# Then add the public key to GitHub:
#   https://github.com/settings/ssh/new

id_ed25519: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  YOUR_PRIVATE_KEY_HERE
  Replace this entire block with your actual private key content.
  The key should be in OpenSSH format (ed25519 recommended).
  -----END OPENSSH PRIVATE KEY-----
id_ed25519_pub: "ssh-ed25519 AAAA... user@host"
